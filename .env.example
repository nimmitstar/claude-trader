# Alpaca Trading API Credentials
# Get these from https://alpaca.markets/
# Use paper trading for development!

# API Key ID
ALPACA_API_KEY=

# API Secret Key
ALPACA_API_SECRET=

# Base URL ( uncomment the one you're using )
# Paper trading (default)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Live trading
# ALPACA_BASE_URL=https://api.alpaca.markets

# Data source ( for market data )
ALPACA_DATA_URL=https://data.alpaca.markets
